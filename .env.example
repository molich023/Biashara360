# ═══════════════════════════════════════════════════════════════
# BIASHARA360 — Environment Variables
# ═══════════════════════════════════════════════════════════════
# DO NOT commit this file to GitHub — add to .gitignore
# Set these in: Netlify Dashboard → Site → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── APP ──────────────────────────────────────────────────────
APP_URL=https://biashara360.netlify.app
# Change to your real URL after deploying e.g. https://biashara360.netlify.app

# ─── NETLIFY DB (Neon PostgreSQL) ─────────────────────────────
# Automatically set by Netlify when you run: npx netlify db init
# IMPORTANT: Claim it immediately — go to Extensions → Neon → Claim Database
NETLIFY_DATABASE_URL=postgresql://...

# ─── M-PESA DARAJA API ────────────────────────────────────────
# Get from: developers.safaricom.co.ke
# Start with sandbox — change to production when ready
MPESA_ENV=sandbox
# sandbox = https://sandbox.safaricom.co.ke
# production = https://api.safaricom.co.ke

MPESA_CONSUMER_KEY=your_consumer_key_from_daraja
MPESA_CONSUMER_SECRET=your_consumer_secret_from_daraja
MPESA_SHORTCODE=174379
# Sandbox shortcode is always 174379
# Production: your real Till or Paybill number

MPESA_PASSKEY=your_mpesa_passkey_from_safaricom_daraja
# Sandbox passkey above is Safaricom's official sandbox passkey
# Production: get from Safaricom after going live

# ─── AI (AKILI — Phase 3, not needed for MVP) ─────────────────
CLAUDE_API_KEY=
GEMINI_API_KEY=

# ─── SMS (Phase 2 — not needed for MVP, we use WhatsApp links) ─
ORAMOBILE_USERNAME=
ORAMOBILE_API_KEY=

# ═══════════════════════════════════════════════════════════════
# SETUP STEPS:
# 1. Create Netlify account at netlify.com
# 2. Connect GitHub repo (github.com/molich023/biashara360)
# 3. Run: npx netlify db init  → sets NETLIFY_DATABASE_URL
# 4. CLAIM database immediately (Extensions → Neon → Claim)
# 5. Run schema: paste 001_initial.sql in Neon SQL editor
# 6. Register on developers.safaricom.co.ke → get sandbox keys
# 7. Add all env vars in Netlify dashboard → Deploy
# ═══════════════════════════════════════════════════════════════
